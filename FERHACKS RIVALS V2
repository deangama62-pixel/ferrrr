-- HITBOX EXPANDER FUNCTIONS
local function ExpandHitbox(character)
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    if humanoid.Health <= 0 then return end
    
    -- Don't expand local player
    if character == LocalPlayer.Character then return end
    
    -- Team check
    local player = Players:GetPlayerFromCharacter(character)
    if player and player.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil then return end
    
    -- Parts to expand
    local partsToExpand = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso"}
    
    for _, partName in ipairs(partsToExpand) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            -- Store original size if not stored
            if not OriginalSizes[part] then
                OriginalSizes[part] = part.Size
            end
            
            -- Expand the hitbox
            if partName == "Head" then
                part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                part.Transparency = 0.9 -- Slightly visible but mostly transparent
                part.CanCollide = false
            else
                part.Size = Vector3.new(HitboxSize, HitboxSize * 1.5, HitboxSize)
                part.Transparency = 1
                part.CanCollide = false
            end
        end
    end
end

local function RestoreHitbox(character)
    if not character then return end
    
    for part, originalSize in pairs(OriginalSizes) do
        if part and part.Parent then
            pcall(function()
                part.Size = originalSize
                part.Transparency = part.Name == "Head" and 0 or 1
            end)
        end
    end
    
    -- Clear stored sizes for this character
    for part, _ in pairs(OriginalSizes) do
        if part.Parent == character or not part.Parent then
            OriginalSizes[part] = nil
        end
    end
end

local function UpdateAllHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if HitboxExpanderEnabled then
                ExpandHitbox(player.Character)
            else
                RestoreHitbox(player.Character)
            end
        end
    end
end

-- GET TARGET PART
local function GetTargetPart(character)
    if not character then return nil end
    
    if HitboxPriority == "Head" then
        return character:FindFirstChild("Head")
    elseif HitboxPriority == "Torso" then
        return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    else
        local head = character:FindFirstChild("Head")
        local torso = character:FindFirstChild("HumanoidRootPart")
        if head and torso then
            local headPos = Camera:WorldToViewportPoint(head.Position)
            local torsoPos = Camera:WorldToViewportPoint(torso.Position)
            local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local headDist = (Vector2.new(headPos.X, headPos.Y) - center).Magnitude
            local torsoDist = (Vector2.new(torsoPos.X, torsoPos.Y) - center).Magnitude
            return headDist < torsoDist and head or torso
        end
        return head or torso
    end
end

-- WALL CHECK
local function IsVisible(targetPart)
    if not WallCheck then return true end
    if not targetPart then return false end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    
    if result then
        local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
        local targetModel = targetPart:FindFirstAncestorOfClass("Model")
        return hitModel == targetModel
    end
    return true
end

-- GET CLOSEST TARGET
local function GetClosestTarget()
    local Closest = nil
    local ClosestDistance = FOVRadius
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local localChar = LocalPlayer.Character
    if not localChar then return nil end
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if player.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil then continue end
            
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end

            local targetPart = GetTargetPart(player.Character)
            if not targetPart then continue end

            local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if not onScreen then continue end
            
            local screenPos = Vector2.new(pos.X, pos.Y)
            local distFromCenter = (screenPos - screenCenter).Magnitude
            local distanceFromPlayer = (targetPart.Position - localRoot.Position).Magnitude
            
            if distFromCenter <= FOVRadius and distanceFromPlayer <= MaxAimDistance then
                if IsVisible(targetPart) then
                    if distFromCenter < ClosestDistance then
                        ClosestDistance = distFromCenter
                        Closest = targetPart
                    end
                end
            end
        end
    end

    return Closest
end

-- AIM LOCK LOOP
RunService.RenderStepped:Connect(function()
    if AimAssistEnabled then
        local target = GetClosestTarget()
        
        if target and target.Parent then
            local hum = target.Parent:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local aimPosition = target.Position
                
                if target:IsA("BasePart") then
                    local velocity = target.Velocity
                    if velocity.Magnitude > 5 then
                        aimPosition = target.Position + (velocity * 0.05)
                    end
                end
                
                local targetCFrame = CFrame.new(Camera.CFrame.Position, aimPosition)
                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Smoothness)
            end
        end
    end
end)

-- ESP FUNCTIONS
local function CreateESP(player)
    if player == LocalPlayer then return end
    if player.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil then return end
    if not player.Character then return end

    local char = player.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    if char:FindFirstChild("FerESP") then char.FerESP:Destroy() end
    if hrp:FindFirstChild("FerInfo") then hrp.FerInfo:Destroy() end

    local highlight = Instance.new("Highlight")
    highlight.Name = "FerESP"
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = char

    local gui = Instance.new("BillboardGui")
    gui.Name = "FerInfo"
    gui.Size = UDim2.new(0, 150, 0, 40)
    gui.StudsOffset = Vector3.new(0, 3, 0)
    gui.AlwaysOnTop = true
    gui.Parent = hrp

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextSize = 12
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.SourceSansBold
    label.Parent = gui

    local connection
    connection = game:GetService("RunService").Heartbeat:Connect(function()
        if not gui.Parent or not hum.Parent then
            connection:Disconnect()
            return
        end

        if player.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil then
            gui.Enabled = false
            highlight.Enabled = false
        else
            gui.Enabled = true
            highlight.Enabled = true
        end

        local localChar = LocalPlayer.Character
        if localChar and localChar:FindFirstChild("HumanoidRootPart") then
            local dist = math.floor((localChar.HumanoidRootPart.Position - hrp.Position).Magnitude)
            label.Text = player.Name .. "\nHP: " .. math.floor(hum.Health) .. " | " .. dist .. "m"
        end
    end)
end

local function RemoveESP(player)
    if not player.Character then return end
    local char = player.Character
    if char:FindFirstChild("FerESP") then char.FerESP:Destroy() end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:FindFirstChild("FerInfo") then hrp.FerInfo:Destroy() end
end

